<!doctype html>
<html lang="pt-br">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <!-- Atualização automática da página a cada 1 hora (3600 segundos) -->
    <meta http-equiv="refresh" content="3600">

    <title>Mural Digital - SUAPE</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/reveal.js/4.6.1/reset.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/reveal.js/4.6.1/reveal.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/reveal.js/4.6.1/theme/black.min.css">

    <style>
        body,
        html {
            margin: 0;
            padding: 0;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
            background-color: #000; /* Fundo preto para evitar flash branco */
        }

        .reveal {
            width: 100vw;
            height: 100vh;
        }

        .reveal .slides {
            width: 100% !important;
            height: 100% !important;
            transform: none !important;
            margin: 0 !important;
            position: absolute;
            top: 0;
            left: 0;
        }

        .reveal .slides section {
            width: 100%;
            height: 100%;
            padding: 0;
            margin: 0;
            top: 0 !important;
        }

        .full-screen-img {
            object-fit: cover;
            width: 100vw;
            height: 100vh;
            display: block;
            margin: 0;
            max-width: none !important;
            max-height: none !important;
        }
    </style>
</head>

<body>
    <div class="reveal">
        <div class="slides">
            {% for image_path in images %}
            <section>
                <img class="full-screen-img" src="{{ image_path }}" alt="Notícia Suape">
            </section>
            {% else %}
            <section>
                <h2>Aguardando notícias...</h2>
            </section>
            {% endfor %}
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/reveal.js/4.6.1/reveal.js"></script>
    <script>
        Reveal.initialize({
            hash: false, controls: false, progress: false, center: false,
            transition: 'fade', autoSlide: {{ slide_duration_ms | default(10000) }}, loop: true,
            width: '100%', height: '100%', margin: 0, minScale: 1, maxScale: 1
        });
    </script>
</body>
</html>